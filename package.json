{
  "name": "jobmate-ai-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight multi-agent core for JobMate AI career interview assistant.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "web:build": "next build",
    "test": "node --import tsx --test tests/*.test.ts",
    "demo": "npm run build && node dist/demo.js",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "typecheck": "tsc -p tsconfig.test.json",
    "build": "tsc -p tsconfig.build.json",
    "chat": "npm run build && node dist/cli/chat.js",
    "real-test": "npm run build && node dist/cli/run-real-test.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  }
}
